{
  "name": "circuito_tvo",
  "version": "1.0.0",
  "description": "MVP Backend - Plataforma de Ecoturismo e Biodiversidade",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
