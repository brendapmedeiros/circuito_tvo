// Esquema do banco

generator client {
  provider = "prisma-client-js"
}

origem db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

modelo trilha {
  id          Int      @id @default(autoincrement())
  nome        String
  dificuldade  String   // "facil" | "moderado" | "dificil"
  distancia    Float    // em quilômetros
  localizacao    String
  descricao String?
  criadoEm   DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  @@map("trilhas")
}

model eventos {
  id          Int      @id @default(autoincrement())
  titulo       String
  data        DateTime
  localizacao    String
  descricao String?
  criadoEm   DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  @@map("eventos")
}

model Biodiversidade {
  id          Int      @id @default(autoincrement())
  nome        String
  tipo        String   
  descricao String?
  criadoEm   DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  @@map("biodiversidade")
}

model eventos_usuarios {
  id          Int      @id @default(autoincrement())
  tipo_evento  String   
  entity_id   Int
  entity_tipo String   
  timestamp   DateTime @default(now())

  @@map("user_eventos")
}
